{
  "manifest_version": 2,
  "default_locale": "en",
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDesc__",
  "version": "1.2.1",
  "author": "Kadimo",
  "homepage_url": "https://github.com/kadimomatheus/proxyflow-containers",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "proxyflow-containers@kadimo",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": true
  },
  "browser_action": {
    "default_title": "ProxyFlow Containers",
    "default_icon": {
      "48": "icons/icon-48.png"
    },
    "default_popup": "popup/popup.html"
  },
  "options_ui": {
    "browser_style": false,
    "page": "options/options.html",
    "open_in_tab": true
  },
  "permissions": [
    "proxy",
    "storage",
    "contextualIdentities",
    "tabs",
    "<all_urls>"
  ]
}
